MODEL_MODE=gemini
MODEL_NAME=gemini-2.5-flash
GEMINI_API_KEY=your-gemini-api-key-here
# VERTEX_PROJECT_ID=your-gcp-project-id
# VERTEX_LOCATION=global
# GOOGLE_APPLICATION_CREDENTIALS=key.json
# Local MySQL sandbox preset:
# see .env.local-mysql.example or run
# python -m scripts.local_mysql.local_stack write-env
DATA_SOURCE=local
LOG_LEVEL=INFO
# Data Acquisition capability gating:
# unset=auto, false=disabled, true=required
# DATA_ACQUISITION_ENABLED=
# DA_LOCAL_DEV=1
# data_acquisition_agent V2 — DB 凭据（运行时由 connection.py 直接读 env，不进 Settings）
DA_DB_HOST=127.0.0.1
DA_DB_PORT=3307
DA_DB_USER=maps_user
DA_DB_PASSWORD=change_me
DA_DB_DATABASE=user_profile
# data_acquisition_agent V2 — 非敏感配置（进 Settings）
DA_MAX_RESULT_ROWS=100000
DA_QUERY_TIMEOUT_SECONDS=60
DA_CONNECTION_PROFILE=default
# Optional isolation dirs for local MySQL sandbox verification:
# APP_BY_UID_DIR=data/local_mysql_test/app/by_uid
# BEHAVIOR_BY_UID_DIR=data/local_mysql_test/behavior/by_uid
# CREDIT_BY_UID_DIR=data/local_mysql_test/credit/by_uid
